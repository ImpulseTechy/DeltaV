NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhrZmhkdnhwZHpkZmlqdWtranhqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEwMTY2NzQsImV4cCI6MjA5NjU5MjY3NH0.3IXaWgjB4vETobLMuLs2l3KYA_gX1RcN09j2fr7XM3w

# Secret Service Role Key (Used in admin routes & webhooks. Keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhrZmhkdnhwZHpkZmlqdWtranhqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTAxNjY3NCwiZXhwIjoyMDk2NTkyNjc0fQ.X_f_TdMiO_iEaAzjhnRLxMfHJXEx1fi1EJ0rapbZdVY


# -------------------------------------------------------------
# 2. RAZORPAY (Payments & Checkout Webhook)
# Create a Razorpay account and get API keys from Dashboard > Settings > API Keys
# -------------------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cryptographic token you define in Razorpay Webhook settings to verify signatures
RAZORPAY_WEBHOOK_SECRET=your_custom_webhook_secret_string


# -------------------------------------------------------------
# 3. RESEND (Transactional Emails)
# Create an account at resend.com, verify your domain, and generate an API key
# -------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key


# -------------------------------------------------------------
# 4. MARKETING & ANALYTICS (Optional for Local Dev)
# -------------------------------------------------------------
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga4_id

# Meta / Facebook Pixel ID (format: 15-digit number)
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id


# -------------------------------------------------------------
# 5. APPLICATION URL (For email links, OpenGraph images, and certificate generation)
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
